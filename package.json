{
  "name": "ham-qso-ai",
  "version": "0.1.0",
  "description": "AI-powered automatic QSO logging from voice streams for amateur radio",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "amateur-radio",
    "ham-radio",
    "qso",
    "voice-recognition",
    "asr",
    "logging",
    "callsign",
    "phonetic-alphabet"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/boybook/ham-qso-ai.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "openai": "^4.86.2",
    "tsx": "^4.21.0",
    "uuid": "^11.1.0",
    "xstate": "^5.19.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.24.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.1.1"
  }
}
